# WimWizard - Git ignore file

# Generated files
WimWizard-AppxList.xml
WimWizard_Launch.ps1

# Log files
*.log
WIMServicing_*.log

# Working directories created during servicing
WIMServicing_Work/
Mount/
Scratch/

# Downloaded updates (large files, re-downloaded automatically)
Updates/

# Output WIM files (large binary files)
Output/
*.wim
*.esd

# ISO files (large binary files)
ISO-Source/
*.iso

# PowerShell session files
*.pssc
*.psd1.bak

# Windows thumbnail cache
Thumbs.db
desktop.ini

# Editor files
.vscode/
*.code-workspace
